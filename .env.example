# Copie para .env e preencha. Nenhum segredo tem valor padrão no código.

# Embeddings (Voyage) — obrigatório
VOYAGE_API_KEY=

# LLM (Groq) — obrigatório
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Weaviate
# WEAVIATE_HTTP_URL=http://weaviate:8080
# WEAVIATE_GRPC_PORT=50051  # do host, use 50052 (mapeamento do docker-compose)
# DEFAULT_COLLECTION=Editais

# Chunking / ingestão
# CHUNK_SIZE=400
# CHUNK_OVERLAP=60
# DATA_DIR=data/editais
# MIN_EXTRACTED_CHARS=100

# Retrieval híbrido
# SEARCH_K=12
# SEARCH_ALPHA=0.6

# Broker (opcional, ingestão assíncrona via Celery)
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
# CELERY_QUEUE=data_ingestion

# Sufixo dos containers no docker-compose
# RAG_ENV=decifra

# Canal Telegram (Fase 3)
# TELEGRAM_BOT_TOKEN=
